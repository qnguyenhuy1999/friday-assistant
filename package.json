{
  "name": "friday-agent-os",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@11.16.0",
  "engines": {
    "node": ">=22 <25"
  },
  "scripts": {
    "format": "prettier --write \"**/*.{json,yaml,yml}\" \"apps/**/*.ts\" \"packages/**/*.ts\" eslint.config.mjs",
    "format:check": "prettier --check \"**/*.{json,yaml,yml}\" \"apps/**/*.ts\" \"packages/**/*.ts\" eslint.config.mjs",
    "lint": "eslint .",
    "typecheck": "tsc --build tsconfig.json"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.7.0",
    "prettier": "^3.9.6",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.65.0"
  }
}
