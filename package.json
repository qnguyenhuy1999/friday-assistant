{
  "name": "friday-agent-os",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@11.16.0",
  "engines": {
    "node": "^20.19.0 || ^22.13.0 || >=24"
  },
  "scripts": {
    "format": "prettier --write \"scripts/**/*.ts\" \"*.json\" \"*.yaml\" eslint.config.mjs",
    "format:check": "prettier --check \"scripts/**/*.ts\" \"*.json\" \"*.yaml\" eslint.config.mjs",
    "lint": "eslint scripts eslint.config.mjs",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.7.0",
    "prettier": "^3.9.6",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.65.0"
  }
}
