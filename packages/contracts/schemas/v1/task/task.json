{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.friday-agent-os.dev/v1/task/task.json",
  "title": "Task",
  "description": "A user-level requested outcome. Mirrors friday.domain.task.Task.",
  "type": "object",
  "properties": {
    "id": { "$ref": "../definitions/identifier.json" },
    "title": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "status": {
      "enum": ["pending", "active", "completed", "failed", "cancelled"]
    },
    "created_at": { "$ref": "../definitions/timestamp.json" },
    "started_at": {
      "anyOf": [{ "$ref": "../definitions/timestamp.json" }, { "type": "null" }]
    },
    "completed_at": {
      "anyOf": [{ "$ref": "../definitions/timestamp.json" }, { "type": "null" }]
    },
    "failed_at": {
      "anyOf": [{ "$ref": "../definitions/timestamp.json" }, { "type": "null" }]
    },
    "cancelled_at": {
      "anyOf": [{ "$ref": "../definitions/timestamp.json" }, { "type": "null" }]
    },
    "failure": {
      "anyOf": [{ "$ref": "../definitions/failure.json" }, { "type": "null" }]
    }
  },
  "required": [
    "id",
    "title",
    "description",
    "status",
    "created_at",
    "started_at",
    "completed_at",
    "failed_at",
    "cancelled_at",
    "failure"
  ],
  "additionalProperties": false
}
